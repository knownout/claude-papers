{
  "name": "claude-papers",
  "version": "1.0.0",
  "description": "Interact with Papers documents on your behalf using API tokens",
  "author": "knownout",
  "mcpServer": {
    "command": "npx",
    "args": ["-y", "claude-papers"],
    "env": {
      "PAPERS_HOST": {
        "description": "Your Papers instance URL (e.g. https://app.wiolett.net)",
        "required": true
      },
      "PAPERS_TOKEN": {
        "description": "Your API access token (tok_...)",
        "required": true
      }
    }
  }
}
